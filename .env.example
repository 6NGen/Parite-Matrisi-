# --- Veri kaynağı ayarları (hepsi opsiyonel) ---

# FRED API anahtarı. Verilmezse public fredgraph.csv uç noktası (anahtarsız) kullanılır.
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# CoinGecko Pro anahtarı (opsiyonel). Verilmezse free public API kullanılır.
COINGECKO_API_KEY=

# Sunucu tarafı fiyat cache TTL (saniye). Varsayılan: günlük 3600, haftalık 21600.
CACHE_TTL_DAILY=3600
CACHE_TTL_WEEKLY=21600

# --- Opsiyonel Supabase fiyat cache (verilmezse bellek-içi cache kullanılır) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
